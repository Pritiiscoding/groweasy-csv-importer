# Port the Express server listens on
PORT=4000

# Which AI provider to use for field extraction: "anthropic" | "openai" | "gemini"
AI_PROVIDER=anthropic

# Only the key for the provider you selected above is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Model overrides (optional, sane defaults are used if omitted)
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# How many raw rows are sent to the AI per request
BATCH_SIZE=20

# Comma separated list of origins allowed to call this API (your deployed frontend URL)
CORS_ORIGIN=http://localhost:3000
